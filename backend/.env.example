# ─────────────────────────────────────────────────────────────────────────────
#  Enterprise Agentic AI L1 Support Automation Platform — Environment Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_HEX
LOG_LEVEL=INFO

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Direct Postgres URL — from Supabase Dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres.your-ref:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_EMBEDDING_DIMENSION=768

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-service-account@your-org.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=KAN
JIRA_WEBHOOK_SECRET=your-jira-webhook-hmac-secret

# ── ServiceNow ────────────────────────────────────────────────────────────────
# Set SERVICENOW_MODE=mock until a real instance is provisioned
SERVICENOW_MODE=mock
SERVICENOW_URL=https://your-instance.service-now.com
SERVICENOW_CLIENT_ID=your-servicenow-oauth-client-id
SERVICENOW_CLIENT_SECRET=your-servicenow-oauth-client-secret
SERVICENOW_USERNAME=your-servicenow-username
SERVICENOW_PASSWORD=your-servicenow-password
SERVICENOW_WEBHOOK_SECRET=your-servicenow-webhook-hmac-secret

# ── Microsoft Graph API ───────────────────────────────────────────────────────
MS_TENANT_ID=your-azure-tenant-id
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_AUTHORITY=https://login.microsoftonline.com/your-azure-tenant-id
MS_OBJECT_ID=your-azure-app-object-id

# ── LDAP / Active Directory (optional — leave blank if not using LDAP) ────────
LDAP_SERVER=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=

# ── Policy engine ─────────────────────────────────────────────────────────────
POLICY_MAX_AUTO_RISK=low
POLICY_BLOCKED_CATEGORIES=finance,executive,security-critical

# ── Notification ─────────────────────────────────────────────────────
# Fallback recipient for send_email when no reporter_email is on the ticket.
# Use your own address in dev/test; a monitored IT queue address in production.
TEST_NOTIFICATION_EMAIL=your-test-email@example.com
