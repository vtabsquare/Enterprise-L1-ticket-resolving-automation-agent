# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=
LOG_LEVEL=INFO

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
DATABASE_URL=

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_EMBEDDING_DIMENSION=768

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=KAN
JIRA_WEBHOOK_SECRET=

# ── ServiceNow ────────────────────────────────────────────────────────────────
SERVICENOW_MODE=mock
SERVICENOW_URL=
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
SERVICENOW_WEBHOOK_SECRET=

# ── Microsoft Graph API ───────────────────────────────────────────────────────
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_AUTHORITY=
MS_OBJECT_ID=

# ── Notification ──────────────────────────────────────────────────────────────
TEST_NOTIFICATION_EMAIL=

# ── LDAP / Active Directory (optional) ────────────────────────────────────────
LDAP_SERVER=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=

# ── Policy engine ─────────────────────────────────────────────────────────────
POLICY_MAX_AUTO_RISK=low
POLICY_BLOCKED_CATEGORIES=finance,executive,security-critical
